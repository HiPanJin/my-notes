---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    class="max-w-app mx-auto w-full px-3 sm:px-4"
  >
    <div
      class="paper-sheet border-border/80 my-5 rounded-[2px] border px-5 py-7 sm:my-8 sm:px-10 sm:py-10"
    >
      <section id="hero" class="px-0 pb-7 pt-0">
        <div class="mb-5 flex items-start justify-between gap-4">
          <h1
            class="manuscript-title text-accent my-0 max-w-2xl text-[2.65rem] leading-[1.08] sm:text-6xl"
          >
            Jin Pan's notes
          </h1>
          <a
            target="_blank"
            href="/rss.xml"
            class="text-accent hover:text-foreground mt-2 inline-block rounded-[2px] p-1 transition hover:-rotate-3"
            aria-label="rss feed"
            title="RSS Feed"
          >
            <IconRss
              width={20}
              height={20}
              class="stroke-3 scale-125 stroke-current rtl:-rotate-90"
            />
            <span class="sr-only">RSS Feed</span>
          </a>
        </div>

        <p class="text-foreground max-w-2xl text-lg leading-9 sm:text-xl">
          One topic, one living page. I keep short notes in place instead of
          turning every thought into a new article.
        </p>
        <p class="margin-note mt-4 max-w-xl">
          Mostly tiny realizations, rough edges, and sentences worth keeping
          before they slip away.
        </p>
        {
          // only display if at least one social link is enabled
          SOCIALS.length > 0 && (
            <div class="note-rule mt-7 flex flex-col pt-4 sm:flex-row sm:items-center">
              <div class="margin-note mb-1 me-2 whitespace-nowrap sm:mb-0">
                Margin notes:
              </div>
              <Socials />
            </div>
          )
        }
      </section>

      {
        featuredPosts.length > 0 && (
          <>
            <div class="note-rule my-8" />
            <section id="featured" class="px-0 pb-4 pt-0">
              <h2 class="manuscript-title text-accent text-3xl leading-tight sm:text-4xl">
                置顶笔记
              </h2>
              <ul>
                {featuredPosts.map(data => (
                  <Card variant="h3" basePath="/notes" {...data} />
                ))}
              </ul>
            </section>
          </>
        )
      }

      {
        recentPosts.length > 0 && (
          <>
            <div class="note-rule my-8" />
            <section id="recent-posts" class="px-0 pb-4 pt-0">
              <h2 class="manuscript-title text-accent text-3xl leading-tight sm:text-4xl">
                最近笔记
              </h2>
              <ul>
                {recentPosts.map(
                  (data, index) =>
                    index < SITE.postPerIndex && (
                      <Card variant="h3" basePath="/notes" {...data} />
                    )
                )}
              </ul>
            </section>
          </>
        )
      }

      <div class="mt-7 text-center">
        <LinkButton
          href="/notes/"
          class="ink-link border-accent/70 inline-flex items-center gap-2 border-b border-dashed pb-1"
        >
          Open all notes
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
