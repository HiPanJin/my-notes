---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    class="mx-auto w-full max-w-app px-4"
  >
    <div
      class="paper-sheet my-6 rounded-sm border border-border/70 px-5 py-8 sm:my-10 sm:px-10 sm:py-12"
    >
      <section id="hero" class="px-0 pt-0 pb-8">
        <div class="mb-4 flex items-start justify-between gap-4">
          <h1
            class="manuscript-title my-0 max-w-2xl text-5xl leading-none text-accent sm:text-6xl"
          >
            Jin Pan — Learning in Public
          </h1>
          <a
            target="_blank"
            href="/rss.xml"
            class="mt-3 inline-block rounded-sm p-1 text-accent transition hover:-rotate-3 hover:text-foreground"
            aria-label="rss feed"
            title="RSS Feed"
          >
            <IconRss
              width={20}
              height={20}
              class="scale-125 stroke-current stroke-3 rtl:-rotate-90"
            />
            <span class="sr-only">RSS Feed</span>
          </a>
        </div>

        <p class="text-lg leading-8 text-foreground">
          I share notes, experiments, and takeaways as I learn in public — from
          SEO and growth experiments to iOS, Swift, SwiftUI, and Go development.
        </p>
        <p class="mt-3 text-ink-soft">
          Focus areas: SEO, iOS, Swift, SwiftUI, Go. Expect a mix of quick tips,
          debugging notes, and longer write-ups.
        </p>
        {
          // only display if at least one social link is enabled
          SOCIALS.length > 0 && (
            <div class="mt-6 flex flex-col border-t border-dashed border-border/80 pt-4 sm:flex-row sm:items-center">
              <div class="me-2 mb-1 whitespace-nowrap text-ink-soft sm:mb-0">
                Margin notes:
              </div>
              <Socials />
            </div>
          )
        }
      </section>

      {
        featuredPosts.length > 0 && (
          <>
            <div class="my-8 border-t border-dashed border-border/80" />
            <section id="featured" class="px-0 pt-0 pb-4">
              <h2 class="manuscript-title text-4xl leading-none text-accent">
                Featured Pages
              </h2>
              <ul>
                {featuredPosts.map(data => (
                  <Card variant="h3" {...data} />
                ))}
              </ul>
            </section>
          </>
        )
      }

      {
        recentPosts.length > 0 && (
          <>
            <div class="my-8 border-t border-dashed border-border/80" />
            <section id="recent-posts" class="px-0 pt-0 pb-4">
              <h2 class="manuscript-title text-4xl leading-none text-accent">
                Notebook Entries
              </h2>
              <ul>
                {recentPosts.map(
                  (data, index) =>
                    index < SITE.postPerIndex && <Card variant="h3" {...data} />
                )}
              </ul>
            </section>
          </>
        )
      }

      <div class="mt-8 text-center">
        <LinkButton
          href="/posts/"
          class="inline-flex items-center gap-2 border-b border-dashed border-accent/70 pb-1 text-accent"
        >
          Open the archive
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
