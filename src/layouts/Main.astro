---
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";

interface StringTitleProp {
  pageTitle: string;
  pageDesc?: string;
}

interface ArrayTitleProp {
  pageTitle: [string, string];
  titleTransition: string;
  pageDesc?: string;
}

export type Props = StringTitleProp | ArrayTitleProp;

const { props } = Astro;

const backUrl = SITE.showBackButton ? Astro.url.pathname : "/";
---

<Breadcrumb />
<main
  data-backUrl={backUrl}
  id="main-content"
  class="mx-auto w-full max-w-app px-4 pb-8"
>
  <div
    class="paper-sheet rounded-sm border border-border/70 px-5 py-8 sm:px-10 sm:py-12"
  >
    {
      "titleTransition" in props ? (
        <h1 class="manuscript-title text-4xl leading-none text-accent sm:text-5xl">
          {props.pageTitle[0]}
          <span transition:name={props.titleTransition}>
            {props.pageTitle[1]}
          </span>
        </h1>
      ) : (
        <h1 class="manuscript-title text-4xl leading-none text-accent sm:text-5xl">
          {props.pageTitle}
        </h1>
      )
    }
    <p class="mt-3 mb-8 text-ink-soft">{props.pageDesc}</p>
    <slot />
  </div>
</main>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent: HTMLElement | null =
      document.querySelector("#main-content");
    const backUrl = mainContent?.dataset?.backurl;
    if (backUrl) {
      sessionStorage.setItem("backUrl", backUrl);
    }
  });
</script>
